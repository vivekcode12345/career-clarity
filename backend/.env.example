DEBUG=True
SECRET_KEY=replace-with-a-secure-random-secret
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
DB_ENGINE=sqlite
ALLOWED_HOSTS=127.0.0.1,localhost,your-backend-domain.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5180,http://localhost:5180,https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5180,http://localhost:5180,https://your-frontend-domain.com
POSTGRES_DB=career_clarity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=CareerClarity <your-email@gmail.com>
FRONTEND_API_URL=https://your-backend-domain.com/api
